{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/donate/paypal.json",
  "description": "Paypal donate button configurations",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "paypal"
    },
    "qrcode": {
      "type": "string",
      "description": "Paypal qrcode image URL"
    }
  },
  "required": ["type", "qrcode"]
}
